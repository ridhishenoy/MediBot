rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow list: if isSignedIn() && resource.data.authUid == request.auth.uid;
      allow get: if isSignedIn();
      allow create: if isSignedIn() && incoming().authUid == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && resource.data.authUid == request.auth.uid && isValidUser(incoming()) && 
        incoming().authUid == request.auth.uid; // Immutable authUid
      
      function isValidUser(data) {
        return data.keys().hasAll(['userId', 'name', 'authUid']) &&
               data.userId is string && data.userId.size() <= 64 &&
               data.authUid == request.auth.uid &&
               data.name is string && data.name.size() <= 100;
      }
    }

    // Measurements
    match /measurements/{measurementId} {
      allow list: if isSignedIn() && resource.data.authUid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.authUid == request.auth.uid;
      allow create: if isSignedIn() && incoming().authUid == request.auth.uid && isValidMeasurement(incoming());
      allow update, delete: if isSignedIn() && resource.data.authUid == request.auth.uid;

      function isValidMeasurement(data) {
        return data.authUid == request.auth.uid &&
               data.userId is string &&
               data.timestamp is string &&
               data.heartRate is number &&
               data.heartRate >= 0 && data.heartRate <= 300;
      }
    }

    // AI Analyses
    match /analyses/{analysisId} {
      allow list, get: if isSignedIn() && resource.data.authUid == request.auth.uid;
      allow create: if isSignedIn() && incoming().authUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.authUid == request.auth.uid;
    }
  }
}
